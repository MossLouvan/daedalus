# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.venv/
venv/
.pytest_cache/

# Env / secrets
.env

# Daedalus forges tools at runtime into ./tools_generated.
# Ignore the forged tools and manifest, but keep the directory tracked.
tools_generated/*.py
tools_generated/manifest.json
!tools_generated/.gitkeep
