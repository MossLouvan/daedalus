# ── Choose ONE provider ───────────────────────────────────────────────

# Anthropic (default)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (or any OpenAI-compatible host)
# DAEDALUS_PROVIDER=openai
# OPENAI_API_KEY=sk-...

# Local / open-source models via Ollama — no API key, no cost
# DAEDALUS_PROVIDER=ollama
# DAEDALUS_MODEL=qwen2.5-coder:7b
# (Ollama serves an OpenAI-compatible API at http://localhost:11434/v1)

# OpenRouter / Together / Groq / vLLM / LM Studio, etc.
# DAEDALUS_PROVIDER=openai
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-...
# DAEDALUS_MODEL=meta-llama/llama-3.1-70b-instruct

# ── Optional tuning ───────────────────────────────────────────────────
# DAEDALUS_MAX_ITERATIONS=40
# DAEDALUS_SANDBOX_TIMEOUT=15
